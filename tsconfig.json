{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "./src",

    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    },

    "isolatedModules": true,
    "jsx": "react-jsx",

    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}